# ============================================================
# YuHou多模态预后预测 - Git忽略规则
# 仅上传代码与配置，不上传大文件（权重/数据/实验输出）
# ============================================================

# ---- Python编译缓存 ----
__pycache__/
*.py[cod]
*.pyo
*.egg-info/
*.egg
dist/
build/

# ---- 虚拟环境 ----
venv/
.venv/
env/
.env
*.env

# ---- IDE配置 ----
.idea/
.vscode/
*.iml
*.swp
*.swo
*~

# ---- 模型权重 (太大, 服务器上单独下载) ----
weights/*
!weights/.gitkeep
*.pth
*.pt
*.ckpt
*.h5
*.pb
*.onnx

# ---- 数据集 (太大, 服务器上单独准备) ----
data/*
!data/.gitkeep

# ---- 实验输出 (运行时生成) ----
experiments/
outputs/
runs/

# ---- 日志文件 ----
logs/
*.log

# ---- 训练输出(检查点/预测pkl/图片) ----
checkpoints/
ckpt/

# ---- 系统文件 ----
.DS_Store
Thumbs.db
desktop.ini

# ---- Jupyter ----
.ipynb_checkpoints/
*.ipynb

# ---- OS杂项 ----
*.tmp
*.temp
*.bak
